{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["src/**/*", "reporters/**/*", "tests/**/*", "pages/**/*", "fixtures/**/*", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
